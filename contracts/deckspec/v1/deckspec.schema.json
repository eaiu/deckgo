{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deckgo.local/contracts/deckspec/v1/deckspec.schema.json",
  "title": "DeckSpec",
  "type": "object",
  "required": ["version", "deckId", "title", "templateId", "theme", "slides"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "deckId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "templateId": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "$ref": "#/$defs/themeSpec"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slideSpec"
      }
    }
  },
  "$defs": {
    "frame": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "minimum": 0 },
        "y": { "type": "number", "minimum": 0 },
        "w": { "type": "number", "exclusiveMinimum": 0 },
        "h": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "themeSpec": {
      "type": "object",
      "required": ["id", "name", "palette"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "palette": {
          "type": "object",
          "required": ["primary", "secondary", "accent", "background", "text"],
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "accent": { "type": "string" },
            "background": { "type": "string" },
            "text": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "slideSpec": {
      "type": "object",
      "required": ["id", "kind", "title", "blocks"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["title", "agenda", "content", "comparison", "timeline", "summary"]
        },
        "title": { "type": "string" },
        "notes": { "type": "string" },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blockSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "blockSpec": {
      "oneOf": [
        { "$ref": "#/$defs/textBlock" },
        { "$ref": "#/$defs/tableBlock" },
        { "$ref": "#/$defs/chartBlock" },
        { "$ref": "#/$defs/imageBlock" },
        { "$ref": "#/$defs/shapeBlock" },
        { "$ref": "#/$defs/diagramArtBlock" }
      ]
    },
    "baseBlock": {
      "type": "object",
      "required": ["id", "kind", "frame", "content"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "frame": {
          "$ref": "#/$defs/frame"
        },
        "content": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "textBlock": {
      "allOf": [
        { "$ref": "#/$defs/baseBlock" },
        {
          "properties": {
            "kind": { "const": "text" },
            "content": {
              "type": "object",
              "required": ["text", "level"],
              "properties": {
                "text": { "type": "string" },
                "level": {
                  "type": "string",
                  "enum": ["h1", "h2", "body", "caption"]
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "tableBlock": {
      "allOf": [
        { "$ref": "#/$defs/baseBlock" },
        {
          "properties": {
            "kind": { "const": "table" },
            "content": {
              "type": "object",
              "required": ["headers", "rows"],
              "properties": {
                "headers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "rows": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "chartBlock": {
      "allOf": [
        { "$ref": "#/$defs/baseBlock" },
        {
          "properties": {
            "kind": { "const": "chart" },
            "content": {
              "type": "object",
              "required": ["chartType", "series"],
              "properties": {
                "chartType": {
                  "type": "string",
                  "enum": ["bar", "line", "pie"]
                },
                "series": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "values"],
                    "properties": {
                      "name": { "type": "string" },
                      "values": {
                        "type": "array",
                        "items": { "type": "number" }
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "imageBlock": {
      "allOf": [
        { "$ref": "#/$defs/baseBlock" },
        {
          "properties": {
            "kind": { "const": "image" },
            "content": {
              "type": "object",
              "required": ["src", "fit"],
              "properties": {
                "src": { "type": "string" },
                "fit": {
                  "type": "string",
                  "enum": ["contain", "cover", "crop"]
                },
                "alt": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "shapeBlock": {
      "allOf": [
        { "$ref": "#/$defs/baseBlock" },
        {
          "properties": {
            "kind": { "const": "shape" },
            "content": {
              "type": "object",
              "required": ["shape", "label"],
              "properties": {
                "shape": {
                  "type": "string",
                  "enum": ["rect", "rounded_rect", "line", "arrow"]
                },
                "label": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "diagramArtBlock": {
      "allOf": [
        { "$ref": "#/$defs/baseBlock" },
        {
          "properties": {
            "kind": { "const": "diagram_art" },
            "content": {
              "type": "object",
              "required": ["svg"],
              "properties": {
                "svg": { "type": "string" },
                "description": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
