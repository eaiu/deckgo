{
  "name": "renderer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts src/cli.ts --format esm --target node18 --out-dir dist",
    "start": "node dist/server.js",
    "render": "tsx src/cli.ts"
  },
  "dependencies": {
    "@deckgo/deck-core": "0.0.1",
    "@deckgo/template-kit": "0.0.1",
    "fastify": "^5.6.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
